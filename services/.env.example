NODE_ENV=production
PORT=5000

# Comma-separated origins allowed to call the backend directly.
CORS_ORIGINS=http://13.126.130.137,https://13.126.130.137,https://aexontech.com,https://www.aexontech.com
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# PostgreSQL / Supabase
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Auth
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL_LOGIN=info@aexontech.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Email
EMAIL_FROM=info@aexontech.com
ADMIN_EMAILS=admin@example.com
SMTP_HOST=smtppro.zoho.in
SMTP_PORT=587
SMTP_USER=info@aexontech.com
SMTP_PASS=replace-with-smtp-app-password
SENDGRID_API_KEY=

# AI
NVIDIA_API_KEY=replace-with-nvidia-api-key
